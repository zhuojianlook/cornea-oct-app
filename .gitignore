# Dependencies & build output
node_modules/
dist/
**/target/
build/

# Python caches
__pycache__/
*.pyc
*.pyo

# Logs
*.log

# Generated per-case working data (kept on disk, not tracked)
cases/
output/

# SAM2 model checkpoint (downloaded, not tracked)
cornea_app/sam2_ckpt/

# Isolated nnU-Net training venv (created on demand, reuses system torch)
cornea_app/.venv-nnunet/

# Local tooling / agent scratch
.agents/
.claude/
*.local.json

# OS
.DS_Store

# sidecar persisted state (no secrets)
cornea_app/python-sidecar/.sidecar_state.json

# Playwright MCP automation artifacts (snapshots, console logs, screenshots)
.playwright-mcp/

# ── Research data & scratch (on disk, never tracked) ──────────────────────────
# The app's real case store: per-case OCT volumes, manifests, labelmaps (~165 GB).
# Irreplaceable user data — kept on disk, never committed.
review_cases/

# Source .OCT acquisitions + companion .txt as exported from the scanner (~27 GB).
# NOTE: gitignore takes the space literally — do not quote the path.
Raw Data/

# Agent/analysis scratch: benchmark harnesses, intermediate volumes, montages.
.work/

# Per-run QA montage output (qa_CS001OS/, qa_defects/, qa_raw/, ...) at repo root.
/qa_*/

# Ad-hoc screenshots and console dumps dropped at the repo root during debugging.
/*.png
/*.out
/*.err

# One-off diagnostic scripts pinned to ephemeral paths (/tmp/ctwt, .work/...).
# Kept on disk for reference; not part of the app.
/dp_diag.py
/gcheck.py
/vetchange.py
/install_virtualbox_7_2.sh
