{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cornea OCT",
  "version": "0.0.186",
  "identifier": "com.cornea.oct",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cornea OCT",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../python-sidecar": "python-sidecar",
      "../../slicer_bridge": "slicer_bridge"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zhuojianlook/cornea-oct-app/releases/download/cornea-updater/cornea-latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1Q0NFQzY3MzRENjRFM0QKUldROVR0WTBaK3pNbFJSbkt2WnRCcHJPQnRkU2w1R3hUZXpQa2gzMmR5NlNTSnpZMW03VzA3dC8K"
    }
  }
}
